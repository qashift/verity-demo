{
  "name": "verity-demo",
  "version": "0.1.0",
  "private": true,
  "description": "A tiny app + Playwright suite to try Verity on real CI and in the cloud.",
  "scripts": {
    "serve": "npx --yes serve public -l 4321",
    "test": "playwright test",
    "verity:fast": "npx --yes @qashift/verity run --tier fast --token $VERITY_INGEST_TOKEN",
    "verity:full": "npx --yes @qashift/verity run --tier full --token $VERITY_INGEST_TOKEN"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0"
  }
}
